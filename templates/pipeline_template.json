{
  "name": "PL_TEMPLATE_WORKFLOW",
  "properties": {
    "description": "Migrated from Informatica workflow: <WORKFLOW_NAME>. Migration date: <DATE>.",
    "activities": [
      {
        "name": "NB_Step1_MappingName",
        "type": "NotebookActivity",
        "dependsOn": [],
        "policy": {
          "timeout": "01:00:00",
          "retry": 1,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "notebook": {
            "referenceName": "NB_<MAPPING_NAME_1>",
            "type": "NotebookReference"
          },
          "parameters": {
            "load_date": {
              "value": "@pipeline().parameters.load_date",
              "type": "string"
            }
          },
          "sparkPool": {
            "referenceName": "default",
            "type": "BigDataPoolReference"
          }
        }
      },
      {
        "name": "NB_Step2_MappingName",
        "type": "NotebookActivity",
        "dependsOn": [
          {
            "activity": "NB_Step1_MappingName",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "01:00:00",
          "retry": 1,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "notebook": {
            "referenceName": "NB_<MAPPING_NAME_2>",
            "type": "NotebookReference"
          },
          "parameters": {
            "load_date": {
              "value": "@pipeline().parameters.load_date",
              "type": "string"
            }
          },
          "sparkPool": {
            "referenceName": "default",
            "type": "BigDataPoolReference"
          }
        }
      }
    ],
    "parameters": {
      "load_date": {
        "type": "string",
        "defaultValue": "@utcnow('yyyy-MM-dd')"
      }
    },
    "annotations": [
      "MigratedFromInformatica",
      "OriginalWorkflow:<WORKFLOW_NAME>"
    ]
  }
}

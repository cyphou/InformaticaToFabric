{
  "name": "PL_TEMPLATE_WORKFLOW",
  "description": "Migrated from Informatica workflow: <WORKFLOW_NAME>. Migration date: <DATE>.",
  "tasks": [
    {
      "task_key": "NB_Step1_MappingName",
      "description": "Migrated from Informatica session S_<MAPPING_NAME_1>.",
      "notebook_task": {
        "notebook_path": "/Workspace/Shared/migration/NB_<MAPPING_NAME_1>",
        "base_parameters": {
          "load_date": "{{job.start_time.iso_date}}"
        }
      },
      "timeout_seconds": 7200,
      "max_retries": 1,
      "min_retry_interval_millis": 30000
    },
    {
      "task_key": "NB_Step2_MappingName",
      "description": "Migrated from Informatica session S_<MAPPING_NAME_2>.",
      "depends_on": [
        {
          "task_key": "NB_Step1_MappingName"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/Shared/migration/NB_<MAPPING_NAME_2>",
        "base_parameters": {
          "load_date": "{{job.start_time.iso_date}}"
        }
      },
      "timeout_seconds": 7200,
      "max_retries": 1,
      "min_retry_interval_millis": 30000
    }
  ],
  "tags": {
    "migrated_from": "informatica",
    "original_workflow": "<WORKFLOW_NAME>"
  },
  "format": "MULTI_TASK",
  "schedule": {
    "quartz_cron_expression": "0 0 6 * * ?",
    "timezone_id": "UTC",
    "pause_status": "PAUSED"
  }
}

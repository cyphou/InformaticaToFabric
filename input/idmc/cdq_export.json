    {
      "id": "cdq-rule-004",
      "name": "DQ_Phone_Format_US",
      "type": "dq_rule",
      "description": "US phone number format validation (10 digits, optional +1 prefix)",
      "createdBy": "dq_admin",
      "updateTime": "2026-02-20T10:00:00Z",
      "tags": ["phone", "format", "us"],
      "dependencies": [],
      "ruleType": "validity",
      "expression": "REGEXP_LIKE(phone, '^\\+?1?[2-9]\\d{2}[2-9]\\d{6}$')",
      "threshold": 90.0,
      "dimensions": ["validity"],
      "targetObjects": ["DIM_CUSTOMER.phone"]
    },
    {
      "id": "cdq-rule-005",
      "name": "DQ_Date_Not_Future",
      "type": "dq_rule",
      "description": "Ensures dates are not in the future (order_date, ship_date)",
      "createdBy": "dq_admin",
      "updateTime": "2026-03-01T09:00:00Z",
      "tags": ["date", "validity"],
      "dependencies": [],
      "ruleType": "validity",
      "expression": "order_date <= CURRENT_DATE",
      "threshold": 99.9,
      "dimensions": ["validity"],
      "targetObjects": ["FACT_ORDERS.order_date", "FACT_ORDERS.ship_date"]
    }
  ]

{
  "objects": [
    {
      "id": "cdq-rule-001",
      "name": "DQ_Customer_Email_Check",
      "type": "dq_rule",
      "description": "Validates customer email format and domain existence",
      "createdBy": "dq_admin",
      "updateTime": "2026-03-10T09:00:00Z",
      "tags": ["email", "customer", "validity"],
      "dependencies": [
        {"component": "cdgc", "name": "Customer_Domain"}
      ],
      "ruleType": "validity",
      "expression": "REGEXP_LIKE(email, '^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$')",
      "threshold": 98.0,
      "dimensions": ["validity", "completeness"],
      "targetObjects": ["DIM_CUSTOMER.email"]
    },
    {
      "id": "cdq-rule-002",
      "name": "DQ_Order_Amount_Range",
      "type": "dq_rule",
      "description": "Ensures order amounts are within acceptable range (0.01–10,000,000)",
      "createdBy": "dq_admin",
      "updateTime": "2026-03-08T14:00:00Z",
      "tags": ["orders", "amount", "range"],
      "dependencies": [],
      "ruleType": "validity",
      "expression": "order_amount BETWEEN 0.01 AND 10000000",
      "threshold": 99.5,
      "dimensions": ["validity"],
      "targetObjects": ["FACT_ORDERS.order_amount"]
    },
    {
      "id": "cdq-rule-003",
      "name": "DQ_Email_Format",
      "type": "dq_rule",
      "description": "Generic email format validation across all string columns tagged as email",
      "createdBy": "dq_admin",
      "updateTime": "2026-02-15T11:00:00Z",
      "tags": ["email", "format", "generic"],
      "dependencies": [],
      "ruleType": "validity",
      "expression": "email IS NOT NULL AND LENGTH(email) > 5",
      "threshold": 95.0,
      "dimensions": ["completeness", "validity"],
      "targetObjects": []
    },
    {

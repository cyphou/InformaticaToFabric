<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE POWERMART SYSTEM "powrmart.dtd">
<POWERMART CREATION_DATE="03/23/2026 10:00:00" REPOSITORY_VERSION="186.90">
<REPOSITORY NAME="PROD_REPO" VERSION="186" DATABASETYPE="Oracle">
<FOLDER NAME="FINANCE_ETL" GROUP="" OWNER="admin" SHARED="NOTSHARED" DESCRIPTION="Finance ETL — Complex workflow with all task types">

<!-- ====================================================================== -->
<!-- WORKFLOW: WF_COMPLEX_FINANCE_ETL                                        -->
<!-- Complex — Timer + Assignment + Worklet + Event Wait/Raise +             -->
<!--           parallel sessions + Decision with multi-branch +              -->
<!--           Scheduler with cron-style repeat + Email on fail/success      -->
<!-- ====================================================================== -->

<WORKFLOW DESCRIPTION="End-of-month finance reconciliation with parallel loads, worklet, events, and conditional branching" ISENABLED="YES" ISRUNNABLE="YES" ISSERVICE="NO" NAME="WF_COMPLEX_FINANCE_ETL" SCHEDULERDBNAME="" SERVERNAME="PROD_SERVER" SUSPEND_ON_ERROR="NO" TASKS_MUST_RUN_ON_SERVER="NO" VERSIONNUMBER="1">

  <!-- =============== TASKS =============== -->

  <!-- Start -->
  <TASK DESCRIPTION="Workflow entry point" NAME="Start" REUSABLE="NO" TYPE="Start" VERSIONNUMBER="1"/>

  <!-- Timer: Wait until market close (6 PM) -->
  <TASK DESCRIPTION="Wait until market close before processing" NAME="TMR_WAIT_MARKET_CLOSE" REUSABLE="NO" TYPE="Timer" VERSIONNUMBER="1">
    <ATTRIBUTE NAME="Timer Type" VALUE="Absolute"/>
    <ATTRIBUTE NAME="Start Time" VALUE="18:00:00"/>
    <ATTRIBUTE NAME="Day of Month" VALUE="$$PROCESSING_DAY"/>
  </TASK>

  <!-- Assignment: Set runtime variables -->
  <TASK DESCRIPTION="Initialize runtime variables" NAME="ASG_INIT_VARS" REUSABLE="NO" TYPE="Assignment" VERSIONNUMBER="1">
    <ATTRIBUTE NAME="Assignment Variable" VALUE="$$BATCH_ID"/>
    <ATTRIBUTE NAME="Assignment Expression" VALUE="TO_CHAR(SYSDATE, 'YYYYMMDD') || '_' || TO_CHAR($$RUN_SEQ)"/>
    <ATTRIBUTE NAME="Assignment Variable" VALUE="$$LOAD_WINDOW_START"/>
    <ATTRIBUTE NAME="Assignment Expression" VALUE="ADD_TO_DATE(TRUNC(SYSDATE), 'DD', -1)"/>
    <ATTRIBUTE NAME="Assignment Variable" VALUE="$$LOAD_WINDOW_END"/>
    <ATTRIBUTE NAME="Assignment Expression" VALUE="TRUNC(SYSDATE)"/>
  </TASK>

  <!-- Session: Load Transactions (from complex mapping) -->
  <SESSION DESCRIPTION="Load transaction facts with multi-source join" ISVALID="YES" MAPPINGNAME="M_COMPLEX_MULTI_SOURCE" NAME="S_LOAD_TRANSACTIONS" REUSABLE="NO" SORTORDER="Binary" VERSIONNUMBER="1">
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="SQ_TRANSACTIONS" STAGE="1" TRANSFORMATIONNAME="SQ_TRANSACTIONS" TRANSFORMATIONTYPE="Source Qualifier"/>
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="SQ_ACCOUNTS" STAGE="1" TRANSFORMATIONNAME="SQ_ACCOUNTS" TRANSFORMATIONTYPE="Source Qualifier"/>
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="JNR_TXN_ACCT" STAGE="2" TRANSFORMATIONNAME="JNR_TXN_ACCT" TRANSFORMATIONTYPE="Joiner"/>
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="MPLT_CURRENCY_CONVERT" STAGE="3" TRANSFORMATIONNAME="MPLT_CURRENCY_CONVERT" TRANSFORMATIONTYPE="Mapplet"/>
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="RTR_VALUE_TIER" STAGE="4" TRANSFORMATIONNAME="RTR_VALUE_TIER" TRANSFORMATIONTYPE="Router"/>
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="RNK_TOP_TXN" STAGE="5" TRANSFORMATIONNAME="RNK_TOP_TXN" TRANSFORMATIONTYPE="Rank"/>
    <CONFIGREFERENCE REFOBJECTNAME="high_perf_session_config" TYPE="Session Config"/>
    <ATTRIBUTE NAME="Parameter Filename" VALUE="$PMRootDir/param/finance_monthly.prm"/>
    <ATTRIBUTE NAME="Pre SQL" VALUE="TRUNCATE TABLE FINANCE.FACT_TXN_STAGING"/>
    <ATTRIBUTE NAME="Post SQL" VALUE="EXEC FINANCE.SP_REFRESH_INDEXES;"/>
    <ATTRIBUTE NAME="Session Log File Name" VALUE="s_load_transactions.log"/>
    <ATTRIBUTE NAME="Session Log File directory" VALUE="$PMSessionLogDir"/>
    <ATTRIBUTE NAME="Maximum Percentage of Errors" VALUE="2"/>
    <ATTRIBUTE NAME="DTM buffer size" VALUE="128000000"/>
    <ATTRIBUTE NAME="Commit Interval" VALUE="50000"/>
  </SESSION>

  <!-- Session: Load Balances (parallel with transactions) -->
  <SESSION DESCRIPTION="Load account balances" ISVALID="YES" MAPPINGNAME="M_LOAD_BALANCES" NAME="S_LOAD_BALANCES" REUSABLE="NO" SORTORDER="Binary" VERSIONNUMBER="1">
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="SQ_BALANCES" STAGE="1" TRANSFORMATIONNAME="SQ_BALANCES" TRANSFORMATIONTYPE="Source Qualifier"/>
    <CONFIGREFERENCE REFOBJECTNAME="default_session_config" TYPE="Session Config"/>
    <ATTRIBUTE NAME="Parameter Filename" VALUE="$PMRootDir/param/finance_monthly.prm"/>
    <ATTRIBUTE NAME="Session Log File Name" VALUE="s_load_balances.log"/>
  </SESSION>

  <!-- Session: Load Exchange Rates (parallel with transactions) -->
  <SESSION DESCRIPTION="Load daily exchange rates" ISVALID="YES" MAPPINGNAME="M_LOAD_FX_RATES" NAME="S_LOAD_FX_RATES" REUSABLE="NO" SORTORDER="Binary" VERSIONNUMBER="1">
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="SQ_FX_RATES" STAGE="1" TRANSFORMATIONNAME="SQ_FX_RATES" TRANSFORMATIONTYPE="Source Qualifier"/>
    <CONFIGREFERENCE REFOBJECTNAME="default_session_config" TYPE="Session Config"/>
    <ATTRIBUTE NAME="Parameter Filename" VALUE="$PMRootDir/param/finance_monthly.prm"/>
    <ATTRIBUTE NAME="Session Log File Name" VALUE="s_load_fx_rates.log"/>
  </SESSION>

  <!-- Decision: Check row counts from all parallel loads -->
  <TASK DESCRIPTION="Verify all loads met minimum thresholds" NAME="DEC_VALIDATE_LOADS" REUSABLE="NO" TYPE="Decision" VERSIONNUMBER="1">
    <ATTRIBUTE NAME="Decision Name" VALUE="DEC_VALIDATE_LOADS"/>
    <ATTRIBUTE NAME="Decision Expression" VALUE="$S_LOAD_TRANSACTIONS.TgtSuccessRows > 100 AND $S_LOAD_BALANCES.TgtSuccessRows > 0 AND $S_LOAD_FX_RATES.TgtSuccessRows > 0"/>
  </TASK>

  <!-- Worklet: Reconciliation sub-workflow -->
  <WORKLET DESCRIPTION="Account reconciliation sub-pipeline" NAME="WKL_RECONCILIATION" REUSABLE="NO" VERSIONNUMBER="1">
    <TASK DESCRIPTION="Worklet start" NAME="Start" REUSABLE="NO" TYPE="Start" VERSIONNUMBER="1"/>

    <SESSION DESCRIPTION="Cross-check transaction totals" ISVALID="YES" MAPPINGNAME="M_RECONCILE_TOTALS" NAME="S_RECONCILE_TOTALS" REUSABLE="NO" SORTORDER="Binary" VERSIONNUMBER="1">
      <SESSTRANSFORMATIONINST PIPELINE="1" SINSTANCENAME="SQ_RECON" STAGE="1" TRANSFORMATIONNAME="SQ_RECON" TRANSFORMATIONTYPE="Source Qualifier"/>
      <CONFIGREFERENCE REFOBJECTNAME="default_session_config" TYPE="Session Config"/>
      <ATTRIBUTE NAME="Session Log File Name" VALUE="s_reconcile_totals.log"/>
    </SESSION>

    <SESSION DESCRIPTION="Generate variance report" ISVALID="YES" MAPPINGNAME="M_VARIANCE_REPORT" NAME="S_VARIANCE_REPORT" REUSABLE="NO" SORTORDER="Binary" VERSIONNUMBER="1">
      <SESSTRANSFORMATIONINST PIPELINE="1" SINSTANCENAME="SQ_VARIANCE" STAGE="1" TRANSFORMATIONNAME="SQ_VARIANCE" TRANSFORMATIONTYPE="Source Qualifier"/>
      <CONFIGREFERENCE REFOBJECTNAME="default_session_config" TYPE="Session Config"/>
      <ATTRIBUTE NAME="Session Log File Name" VALUE="s_variance_report.log"/>
    </SESSION>

    <TASKINSTANCE NAME="Start" TASKNAME="Start" TASKTYPE="Start"/>
    <TASKINSTANCE NAME="S_RECONCILE_TOTALS" TASKNAME="S_RECONCILE_TOTALS" TASKTYPE="Session"/>
    <TASKINSTANCE NAME="S_VARIANCE_REPORT" TASKNAME="S_VARIANCE_REPORT" TASKTYPE="Session"/>

    <WORKFLOWLINK CONDITION="" FROMTASK="Start" TOTASK="S_RECONCILE_TOTALS"/>
    <WORKFLOWLINK CONDITION="$S_RECONCILE_TOTALS.Status = SUCCEEDED" FROMTASK="S_RECONCILE_TOTALS" TOTASK="S_VARIANCE_REPORT"/>
  </WORKLET>

  <!-- Event Wait: Wait for external file arrival -->
  <TASK DESCRIPTION="Wait for upstream system to signal completion" NAME="EVT_WAIT_UPSTREAM" REUSABLE="NO" TYPE="Event Wait" VERSIONNUMBER="1">
    <ATTRIBUTE NAME="Event Name" VALUE="EVT_UPSTREAM_READY"/>
    <ATTRIBUTE NAME="Wait Type" VALUE="Predefined"/>
    <ATTRIBUTE NAME="Timeout" VALUE="3600"/>
  </TASK>

  <!-- Event Raise: Signal downstream -->
  <TASK DESCRIPTION="Signal that finance ETL is complete" NAME="EVT_RAISE_COMPLETE" REUSABLE="NO" TYPE="Event Raise" VERSIONNUMBER="1">
    <ATTRIBUTE NAME="Event Name" VALUE="EVT_FINANCE_ETL_DONE"/>
  </TASK>

  <!-- Email: Success -->
  <TASK DESCRIPTION="Send success notification" NAME="EMAIL_SUCCESS" REUSABLE="NO" TYPE="Email" VERSIONNUMBER="1">
    <ATTRIBUTE NAME="Email User Name" VALUE="finance-etl@company.com"/>
    <ATTRIBUTE NAME="Email Subject" VALUE="WF_COMPLEX_FINANCE_ETL SUCCEEDED — Batch $$BATCH_ID"/>
    <ATTRIBUTE NAME="Email Text" VALUE="Finance ETL completed successfully. Transactions: $S_LOAD_TRANSACTIONS.TgtSuccessRows rows. Reconciliation complete."/>
  </TASK>

  <!-- Email: Failure -->
  <TASK DESCRIPTION="Send failure notification" NAME="EMAIL_FAILURE" REUSABLE="NO" TYPE="Email" VERSIONNUMBER="1">
    <ATTRIBUTE NAME="Email User Name" VALUE="finance-etl@company.com;oncall-dba@company.com"/>
    <ATTRIBUTE NAME="Email Subject" VALUE="ALERT: WF_COMPLEX_FINANCE_ETL FAILED — Batch $$BATCH_ID"/>
    <ATTRIBUTE NAME="Email Text" VALUE="The finance ETL workflow failed. Batch: $$BATCH_ID. Check session logs immediately."/>
  </TASK>

  <!-- =============== TASK INSTANCES =============== -->
  <TASKINSTANCE NAME="Start" TASKNAME="Start" TASKTYPE="Start"/>
  <TASKINSTANCE NAME="TMR_WAIT_MARKET_CLOSE" TASKNAME="TMR_WAIT_MARKET_CLOSE" TASKTYPE="Timer"/>
  <TASKINSTANCE NAME="ASG_INIT_VARS" TASKNAME="ASG_INIT_VARS" TASKTYPE="Assignment"/>
  <TASKINSTANCE NAME="EVT_WAIT_UPSTREAM" TASKNAME="EVT_WAIT_UPSTREAM" TASKTYPE="Event Wait"/>
  <TASKINSTANCE NAME="S_LOAD_TRANSACTIONS" TASKNAME="S_LOAD_TRANSACTIONS" TASKTYPE="Session"/>
  <TASKINSTANCE NAME="S_LOAD_BALANCES" TASKNAME="S_LOAD_BALANCES" TASKTYPE="Session"/>
  <TASKINSTANCE NAME="S_LOAD_FX_RATES" TASKNAME="S_LOAD_FX_RATES" TASKTYPE="Session"/>
  <TASKINSTANCE NAME="DEC_VALIDATE_LOADS" TASKNAME="DEC_VALIDATE_LOADS" TASKTYPE="Decision"/>
  <TASKINSTANCE NAME="WKL_RECONCILIATION" TASKNAME="WKL_RECONCILIATION" TASKTYPE="Worklet"/>
  <TASKINSTANCE NAME="EVT_RAISE_COMPLETE" TASKNAME="EVT_RAISE_COMPLETE" TASKTYPE="Event Raise"/>
  <TASKINSTANCE NAME="EMAIL_SUCCESS" TASKNAME="EMAIL_SUCCESS" TASKTYPE="Email"/>
  <TASKINSTANCE NAME="EMAIL_FAILURE" TASKNAME="EMAIL_FAILURE" TASKTYPE="Email"/>

  <!-- =============== LINKS / DEPENDENCIES =============== -->

  <!-- Phase 0: Start → Timer → Assignment → Event Wait -->
  <WORKFLOWLINK CONDITION="" FROMTASK="Start" TOTASK="TMR_WAIT_MARKET_CLOSE"/>
  <WORKFLOWLINK CONDITION="" FROMTASK="TMR_WAIT_MARKET_CLOSE" TOTASK="ASG_INIT_VARS"/>
  <WORKFLOWLINK CONDITION="" FROMTASK="ASG_INIT_VARS" TOTASK="EVT_WAIT_UPSTREAM"/>

  <!-- Phase 1: Parallel loads (after upstream ready) -->
  <WORKFLOWLINK CONDITION="" FROMTASK="EVT_WAIT_UPSTREAM" TOTASK="S_LOAD_TRANSACTIONS"/>
  <WORKFLOWLINK CONDITION="" FROMTASK="EVT_WAIT_UPSTREAM" TOTASK="S_LOAD_BALANCES"/>
  <WORKFLOWLINK CONDITION="" FROMTASK="EVT_WAIT_UPSTREAM" TOTASK="S_LOAD_FX_RATES"/>

  <!-- Phase 2: Validate after ALL parallel loads complete -->
  <WORKFLOWLINK CONDITION="$S_LOAD_TRANSACTIONS.Status = SUCCEEDED" FROMTASK="S_LOAD_TRANSACTIONS" TOTASK="DEC_VALIDATE_LOADS"/>
  <WORKFLOWLINK CONDITION="$S_LOAD_BALANCES.Status = SUCCEEDED" FROMTASK="S_LOAD_BALANCES" TOTASK="DEC_VALIDATE_LOADS"/>
  <WORKFLOWLINK CONDITION="$S_LOAD_FX_RATES.Status = SUCCEEDED" FROMTASK="S_LOAD_FX_RATES" TOTASK="DEC_VALIDATE_LOADS"/>

  <!-- Phase 2 failure paths -->
  <WORKFLOWLINK CONDITION="$S_LOAD_TRANSACTIONS.Status = FAILED" FROMTASK="S_LOAD_TRANSACTIONS" TOTASK="EMAIL_FAILURE"/>
  <WORKFLOWLINK CONDITION="$S_LOAD_BALANCES.Status = FAILED" FROMTASK="S_LOAD_BALANCES" TOTASK="EMAIL_FAILURE"/>
  <WORKFLOWLINK CONDITION="$S_LOAD_FX_RATES.Status = FAILED" FROMTASK="S_LOAD_FX_RATES" TOTASK="EMAIL_FAILURE"/>

  <!-- Phase 3: Decision → Worklet or Failure -->
  <WORKFLOWLINK CONDITION="$DEC_VALIDATE_LOADS.condition = TRUE" FROMTASK="DEC_VALIDATE_LOADS" TOTASK="WKL_RECONCILIATION"/>
  <WORKFLOWLINK CONDITION="$DEC_VALIDATE_LOADS.condition = FALSE" FROMTASK="DEC_VALIDATE_LOADS" TOTASK="EMAIL_FAILURE"/>

  <!-- Phase 4: Worklet → Signal + Email -->
  <WORKFLOWLINK CONDITION="$WKL_RECONCILIATION.Status = SUCCEEDED" FROMTASK="WKL_RECONCILIATION" TOTASK="EVT_RAISE_COMPLETE"/>
  <WORKFLOWLINK CONDITION="$WKL_RECONCILIATION.Status = FAILED" FROMTASK="WKL_RECONCILIATION" TOTASK="EMAIL_FAILURE"/>
  <WORKFLOWLINK CONDITION="" FROMTASK="EVT_RAISE_COMPLETE" TOTASK="EMAIL_SUCCESS"/>

  <!-- =============== SCHEDULER =============== -->

  <!-- Cron-style: Run on last business day of month at 5:30 PM -->
  <SCHEDULER DESCRIPTION="End-of-month at 5:30 PM UTC" NAME="SCHED_EOM_1730" REUSABLE="NO" VERSIONNUMBER="1">
    <SCHEDULEINFO SCHEDULETYPE="Customized_Repeat">
      <ATTRIBUTE NAME="Repeat Type" VALUE="Monthly"/>
      <ATTRIBUTE NAME="Day of Month" VALUE="Last"/>
      <ATTRIBUTE NAME="Start Time" VALUE="17:30"/>
      <ATTRIBUTE NAME="End On" VALUE="No End Date"/>
      <ATTRIBUTE NAME="Run On Weekdays Only" VALUE="YES"/>
    </SCHEDULEINFO>
  </SCHEDULER>

</WORKFLOW>

</FOLDER>
</REPOSITORY>
</POWERMART>

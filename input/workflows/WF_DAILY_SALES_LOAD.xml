<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE POWERMART SYSTEM "powrmart.dtd">
<POWERMART CREATION_DATE="03/23/2026 10:00:00" REPOSITORY_VERSION="186.90">
<REPOSITORY NAME="PROD_REPO" VERSION="186" DATABASETYPE="Oracle">
<FOLDER NAME="SALES_ETL" GROUP="" OWNER="admin" SHARED="NOTSHARED" DESCRIPTION="Sales ETL Workflows">

<!-- ============================================================ -->
<!-- WORKFLOW: WF_DAILY_SALES_LOAD                                 -->
<!-- Sequential: Load Customers → Load Orders → Upsert Inventory   -->
<!-- ============================================================ -->

<WORKFLOW DESCRIPTION="Daily sales data load pipeline" ISENABLED="YES" ISRUNNABLE="YES" ISSERVICE="NO" NAME="WF_DAILY_SALES_LOAD" SCHEDULERDBNAME="" SERVERNAME="PROD_SERVER" SUSPEND_ON_ERROR="NO" TASKS_MUST_RUN_ON_SERVER="NO" VERSIONNUMBER="1">

  <!-- Start Task -->
  <TASK DESCRIPTION="Workflow start" NAME="Start" REUSABLE="NO" TYPE="Start" VERSIONNUMBER="1"/>

  <!-- Session: Load Customers -->
  <SESSION DESCRIPTION="Load customer dimension" ISVALID="YES" MAPPINGNAME="M_LOAD_CUSTOMERS" NAME="S_M_LOAD_CUSTOMERS" REUSABLE="NO" SORTORDER="Binary" VERSIONNUMBER="1">
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="SQ_CUSTOMERS" STAGE="1" TRANSFORMATIONNAME="SQ_CUSTOMERS" TRANSFORMATIONTYPE="Source Qualifier"/>
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="EXP_DERIVE_FIELDS" STAGE="1" TRANSFORMATIONNAME="EXP_DERIVE_FIELDS" TRANSFORMATIONTYPE="Expression"/>
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="FIL_ACTIVE_CUSTOMERS" STAGE="1" TRANSFORMATIONNAME="FIL_ACTIVE_CUSTOMERS" TRANSFORMATIONTYPE="Filter"/>
    <CONFIGREFERENCE REFOBJECTNAME="default_session_config" TYPE="Session Config"/>
    <ATTRIBUTE NAME="Parameter Filename" VALUE="$PMRootDir/param/sales_daily.prm"/>
    <ATTRIBUTE NAME="Write Backward Compatible Session Log File" VALUE="NO"/>
    <ATTRIBUTE NAME="Session Log File Name" VALUE="s_m_load_customers.log"/>
    <ATTRIBUTE NAME="Session Log File directory" VALUE="$PMSessionLogDir"/>
    <ATTRIBUTE NAME="Maximum Percentage of Errors" VALUE="0"/>
  </SESSION>

  <!-- Session: Load Orders (with SQL Override) -->
  <SESSION DESCRIPTION="Load orders fact table with aggregation" ISVALID="YES" MAPPINGNAME="M_LOAD_ORDERS" NAME="S_M_LOAD_ORDERS" REUSABLE="NO" SORTORDER="Binary" VERSIONNUMBER="1">
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="SQ_ORDERS" STAGE="1" TRANSFORMATIONNAME="SQ_ORDERS" TRANSFORMATIONTYPE="Source Qualifier"/>
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="LKP_PRODUCTS" STAGE="1" TRANSFORMATIONNAME="LKP_PRODUCTS" TRANSFORMATIONTYPE="Lookup Procedure"/>
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="EXP_CALC_TOTAL" STAGE="1" TRANSFORMATIONNAME="EXP_CALC_TOTAL" TRANSFORMATIONTYPE="Expression"/>
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="AGG_BY_CUSTOMER" STAGE="1" TRANSFORMATIONNAME="AGG_BY_CUSTOMER" TRANSFORMATIONTYPE="Aggregator"/>
    <CONFIGREFERENCE REFOBJECTNAME="default_session_config" TYPE="Session Config"/>
    <ATTRIBUTE NAME="Parameter Filename" VALUE="$PMRootDir/param/sales_daily.prm"/>
    <ATTRIBUTE NAME="Pre SQL" VALUE="DELETE FROM SALES.FACT_ORDERS_STAGING WHERE ORDER_DATE = TO_DATE('$$LOAD_DATE','YYYY-MM-DD')"/>
    <ATTRIBUTE NAME="Post SQL" VALUE="EXEC SALES.SP_UPDATE_ORDER_STATS;"/>
    <ATTRIBUTE NAME="Session Log File Name" VALUE="s_m_load_orders.log"/>
    <ATTRIBUTE NAME="Maximum Percentage of Errors" VALUE="5"/>
  </SESSION>

  <!-- Session: Upsert Inventory -->
  <SESSION DESCRIPTION="Merge inventory updates" ISVALID="YES" MAPPINGNAME="M_UPSERT_INVENTORY" NAME="S_M_UPSERT_INVENTORY" REUSABLE="NO" SORTORDER="Binary" VERSIONNUMBER="1">
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="SQ_STG_INVENTORY" STAGE="1" TRANSFORMATIONNAME="SQ_STG_INVENTORY" TRANSFORMATIONTYPE="Source Qualifier"/>
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="EXP_CALC_AVAILABLE" STAGE="1" TRANSFORMATIONNAME="EXP_CALC_AVAILABLE" TRANSFORMATIONTYPE="Expression"/>
    <SESSTRANSFORMATIONINST ISREPARTITIONPOINT="NO" PARTITIONTYPE="NONE" PIPELINE="1" SINSTANCENAME="UPD_INVENTORY" STAGE="1" TRANSFORMATIONNAME="UPD_INVENTORY" TRANSFORMATIONTYPE="Update Strategy"/>
    <CONFIGREFERENCE REFOBJECTNAME="default_session_config" TYPE="Session Config"/>
    <ATTRIBUTE NAME="Parameter Filename" VALUE="$PMRootDir/param/sales_daily.prm"/>
    <ATTRIBUTE NAME="Session Log File Name" VALUE="s_m_upsert_inventory.log"/>
  </SESSION>

  <!-- Decision: Check if orders loaded successfully -->
  <TASK DESCRIPTION="Check order row count threshold" NAME="DEC_CHECK_ORDERS" REUSABLE="NO" TYPE="Decision" VERSIONNUMBER="1">
    <ATTRIBUTE NAME="Decision Name" VALUE="DEC_CHECK_ORDERS"/>
    <ATTRIBUTE NAME="Decision Expression" VALUE="$S_M_LOAD_ORDERS.TgtSuccessRows > 0"/>
  </TASK>

  <!-- Email Task: Send failure notification -->
  <TASK DESCRIPTION="Send email on failure" NAME="EMAIL_FAILURE" REUSABLE="NO" TYPE="Email" VERSIONNUMBER="1">
    <ATTRIBUTE NAME="Email User Name" VALUE="etl-alerts@company.com"/>
    <ATTRIBUTE NAME="Email Subject" VALUE="WF_DAILY_SALES_LOAD FAILED - $$LOAD_DATE"/>
    <ATTRIBUTE NAME="Email Text" VALUE="The daily sales load workflow failed. Please check the session logs."/>
  </TASK>

  <!-- Task instances and links -->
  <TASKINSTANCE DESCRIPTION="" NAME="Start" TASKNAME="Start" TASKTYPE="Start"/>
  <TASKINSTANCE DESCRIPTION="" NAME="S_M_LOAD_CUSTOMERS" TASKNAME="S_M_LOAD_CUSTOMERS" TASKTYPE="Session"/>
  <TASKINSTANCE DESCRIPTION="" NAME="S_M_LOAD_ORDERS" TASKNAME="S_M_LOAD_ORDERS" TASKTYPE="Session"/>
  <TASKINSTANCE DESCRIPTION="" NAME="S_M_UPSERT_INVENTORY" TASKNAME="S_M_UPSERT_INVENTORY" TASKTYPE="Session"/>
  <TASKINSTANCE DESCRIPTION="" NAME="DEC_CHECK_ORDERS" TASKNAME="DEC_CHECK_ORDERS" TASKTYPE="Decision"/>
  <TASKINSTANCE DESCRIPTION="" NAME="EMAIL_FAILURE" TASKNAME="EMAIL_FAILURE" TASKTYPE="Email"/>

  <!-- Links / Dependencies -->
  <WORKFLOWLINK CONDITION="" FROMTASK="Start" TOTASK="S_M_LOAD_CUSTOMERS"/>
  <WORKFLOWLINK CONDITION="$S_M_LOAD_CUSTOMERS.Status = SUCCEEDED" FROMTASK="S_M_LOAD_CUSTOMERS" TOTASK="S_M_LOAD_ORDERS"/>
  <WORKFLOWLINK CONDITION="$S_M_LOAD_CUSTOMERS.Status = FAILED" FROMTASK="S_M_LOAD_CUSTOMERS" TOTASK="EMAIL_FAILURE"/>
  <WORKFLOWLINK CONDITION="" FROMTASK="S_M_LOAD_ORDERS" TOTASK="DEC_CHECK_ORDERS"/>
  <WORKFLOWLINK CONDITION="$DEC_CHECK_ORDERS.condition = TRUE" FROMTASK="DEC_CHECK_ORDERS" TOTASK="S_M_UPSERT_INVENTORY"/>
  <WORKFLOWLINK CONDITION="$DEC_CHECK_ORDERS.condition = FALSE" FROMTASK="DEC_CHECK_ORDERS" TOTASK="EMAIL_FAILURE"/>

  <!-- Scheduler: Daily at 02:00 UTC -->
  <SCHEDULER DESCRIPTION="Daily 2AM UTC" NAME="SCHED_DAILY_0200" REUSABLE="NO" VERSIONNUMBER="1">
    <SCHEDULEINFO SCHEDULETYPE="RunOnce_Repeat">
      <ATTRIBUTE NAME="Repeat Type" VALUE="Every Day"/>
      <ATTRIBUTE NAME="Start Time" VALUE="02:00"/>
      <ATTRIBUTE NAME="End On" VALUE="No End Date"/>
    </SCHEDULEINFO>
  </SCHEDULER>

</WORKFLOW>

</FOLDER>
</REPOSITORY>
</POWERMART>

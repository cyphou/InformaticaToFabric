<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE POWERMART SYSTEM "powrmart.dtd">
<POWERMART CREATION_DATE="03/23/2026 10:00:00" REPOSITORY_VERSION="186.90">
<REPOSITORY NAME="PROD_REPO" VERSION="186" DATABASETYPE="Oracle">
<FOLDER NAME="SALES_ETL" GROUP="" OWNER="admin" SHARED="NOTSHARED" DESCRIPTION="Sales ETL Mappings">

<!-- ================================================================ -->
<!-- MAPPING: M_LOAD_ORDERS (Medium — SQ → LKP → AGG → JNR → TGT)   -->
<!-- ================================================================ -->

<!-- Source: ORDERS -->
<SOURCE BUSINESSNAME="" DATABASETYPE="Oracle" DBDNAME="ORACLE_PROD" DESCRIPTION="Orders transaction table" NAME="ORDERS" OBJECTVERSION="1" OWNERNAME="SALES" VERSIONNUMBER="1">
  <SOURCEFIELD BUSINESSNAME="" DATATYPE="number" FIELDNUMBER="1" NAME="ORDER_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <SOURCEFIELD BUSINESSNAME="" DATATYPE="number" FIELDNUMBER="2" NAME="CUSTOMER_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <SOURCEFIELD BUSINESSNAME="" DATATYPE="number" FIELDNUMBER="3" NAME="PRODUCT_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <SOURCEFIELD BUSINESSNAME="" DATATYPE="number" FIELDNUMBER="4" NAME="QUANTITY" NULLABLE="NULL" PRECISION="10" SCALE="0"/>
  <SOURCEFIELD BUSINESSNAME="" DATATYPE="number" FIELDNUMBER="5" NAME="UNIT_PRICE" NULLABLE="NULL" PRECISION="12" SCALE="2"/>
  <SOURCEFIELD BUSINESSNAME="" DATATYPE="number" FIELDNUMBER="6" NAME="DISCOUNT_PCT" NULLABLE="NULL" PRECISION="5" SCALE="2"/>
  <SOURCEFIELD BUSINESSNAME="" DATATYPE="date" FIELDNUMBER="7" NAME="ORDER_DATE" NULLABLE="NULL" PRECISION="19" SCALE="0"/>
  <SOURCEFIELD BUSINESSNAME="" DATATYPE="varchar2" FIELDNUMBER="8" NAME="ORDER_STATUS" NULLABLE="NULL" PRECISION="20" SCALE="0"/>
  <SOURCEFIELD BUSINESSNAME="" DATATYPE="varchar2" FIELDNUMBER="9" NAME="CHANNEL" NULLABLE="NULL" PRECISION="20" SCALE="0"/>
</SOURCE>

<!-- Source: PRODUCTS (lookup) -->
<SOURCE BUSINESSNAME="" DATABASETYPE="Oracle" DBDNAME="ORACLE_PROD" DESCRIPTION="Product reference table" NAME="PRODUCTS" OBJECTVERSION="1" OWNERNAME="SALES" VERSIONNUMBER="1">
  <SOURCEFIELD BUSINESSNAME="" DATATYPE="number" FIELDNUMBER="1" NAME="PRODUCT_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <SOURCEFIELD BUSINESSNAME="" DATATYPE="varchar2" FIELDNUMBER="2" NAME="PRODUCT_NAME" NULLABLE="NULL" PRECISION="200" SCALE="0"/>
  <SOURCEFIELD BUSINESSNAME="" DATATYPE="varchar2" FIELDNUMBER="3" NAME="CATEGORY" NULLABLE="NULL" PRECISION="50" SCALE="0"/>
</SOURCE>

<!-- Target: FACT_ORDERS -->
<TARGET BUSINESSNAME="" DATABASETYPE="Oracle" DESCRIPTION="Silver fact table for orders" NAME="FACT_ORDERS" OBJECTVERSION="1">
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="1" KEYTYPE="PRIMARY KEY" NAME="ORDER_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="2" KEYTYPE="NOT A KEY" NAME="CUSTOMER_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="3" KEYTYPE="NOT A KEY" NAME="PRODUCT_NAME" NULLABLE="NULL" PRECISION="200" SCALE="0"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="4" KEYTYPE="NOT A KEY" NAME="CATEGORY" NULLABLE="NULL" PRECISION="50" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="5" KEYTYPE="NOT A KEY" NAME="QUANTITY" NULLABLE="NULL" PRECISION="10" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="6" KEYTYPE="NOT A KEY" NAME="UNIT_PRICE" NULLABLE="NULL" PRECISION="12" SCALE="2"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="7" KEYTYPE="NOT A KEY" NAME="LINE_TOTAL" NULLABLE="NULL" PRECISION="15" SCALE="2"/>
  <TARGETFIELD DATATYPE="date" FIELDNUMBER="8" KEYTYPE="NOT A KEY" NAME="ORDER_DATE" NULLABLE="NULL" PRECISION="19" SCALE="0"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="9" KEYTYPE="NOT A KEY" NAME="ORDER_STATUS" NULLABLE="NULL" PRECISION="20" SCALE="0"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="10" KEYTYPE="NOT A KEY" NAME="CHANNEL" NULLABLE="NULL" PRECISION="20" SCALE="0"/>
</TARGET>

<!-- Target: AGG_ORDERS_BY_CUSTOMER -->
<TARGET BUSINESSNAME="" DATABASETYPE="Oracle" DESCRIPTION="Gold aggregate orders by customer" NAME="AGG_ORDERS_BY_CUSTOMER" OBJECTVERSION="1">
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="1" KEYTYPE="PRIMARY KEY" NAME="CUSTOMER_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="2" KEYTYPE="NOT A KEY" NAME="TOTAL_ORDERS" NULLABLE="NULL" PRECISION="10" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="3" KEYTYPE="NOT A KEY" NAME="TOTAL_REVENUE" NULLABLE="NULL" PRECISION="18" SCALE="2"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="4" KEYTYPE="NOT A KEY" NAME="AVG_ORDER_VALUE" NULLABLE="NULL" PRECISION="15" SCALE="2"/>
</TARGET>

<MAPPING DESCRIPTION="Load orders with product lookup and customer aggregation" ISVALID="YES" NAME="M_LOAD_ORDERS" OBJECTVERSION="1" VERSIONNUMBER="1">

  <!-- Source Qualifier with SQL Override -->
  <TRANSFORMATION DESCRIPTION="Read orders with date filter" NAME="SQ_ORDERS" OBJECTVERSION="1" REUSABLE="NO" TYPE="Source Qualifier" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="ORDER_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="CUSTOMER_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="PRODUCT_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="QUANTITY" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="UNIT_PRICE" PORTTYPE="INPUT/OUTPUT" PRECISION="12" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="DISCOUNT_PCT" PORTTYPE="INPUT/OUTPUT" PRECISION="5" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="ORDER_DATE" PORTTYPE="INPUT/OUTPUT" PRECISION="19" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="ORDER_STATUS" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="CHANNEL" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT ORDER_ID, CUSTOMER_ID, PRODUCT_ID, QUANTITY, UNIT_PRICE, NVL(DISCOUNT_PCT, 0) AS DISCOUNT_PCT, ORDER_DATE, ORDER_STATUS, CHANNEL FROM SALES.ORDERS WHERE ORDER_DATE >= TO_DATE('$$LOAD_DATE', 'YYYY-MM-DD') AND ORDER_STATUS != 'CANCELLED'"/>
    <TABLEATTRIBUTE NAME="User Defined Join" VALUE=""/>
    <TABLEATTRIBUTE NAME="Source Filter" VALUE=""/>
  </TRANSFORMATION>

  <!-- Lookup: Product details -->
  <TRANSFORMATION DESCRIPTION="Lookup product name and category" NAME="LKP_PRODUCTS" OBJECTVERSION="1" REUSABLE="NO" TYPE="Lookup Procedure" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="IN_PRODUCT_ID" PORTTYPE="INPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="PRODUCT_ID" PORTTYPE="OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="PRODUCT_NAME" PORTTYPE="OUTPUT" PRECISION="200" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="CATEGORY" PORTTYPE="OUTPUT" PRECISION="50" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Lookup table name" VALUE="SALES.PRODUCTS"/>
    <TABLEATTRIBUTE NAME="Lookup Sql Override" VALUE="SELECT PRODUCT_ID, NVL(PRODUCT_NAME, 'Unknown') AS PRODUCT_NAME, NVL(CATEGORY, 'Uncategorized') AS CATEGORY FROM SALES.PRODUCTS"/>
    <TABLEATTRIBUTE NAME="Lookup condition" VALUE="IN_PRODUCT_ID = PRODUCT_ID"/>
    <TABLEATTRIBUTE NAME="Connection Information" VALUE="ORACLE_PROD"/>
    <TABLEATTRIBUTE NAME="Lookup Policy on Multiple Match" VALUE="Use First Value"/>
  </TRANSFORMATION>

  <!-- Expression: Calculate line_total -->
  <TRANSFORMATION DESCRIPTION="Calculate line total with discount" NAME="EXP_CALC_TOTAL" OBJECTVERSION="1" REUSABLE="NO" TYPE="Expression" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="ORDER_ID" NAME="ORDER_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="CUSTOMER_ID" NAME="CUSTOMER_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" EXPRESSION="PRODUCT_NAME" NAME="PRODUCT_NAME" PORTTYPE="INPUT/OUTPUT" PRECISION="200" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" EXPRESSION="CATEGORY" NAME="CATEGORY" PORTTYPE="INPUT/OUTPUT" PRECISION="50" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="QUANTITY" NAME="QUANTITY" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="UNIT_PRICE" NAME="UNIT_PRICE" PORTTYPE="INPUT/OUTPUT" PRECISION="12" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="QUANTITY * UNIT_PRICE * (1 - DISCOUNT_PCT / 100)" NAME="LINE_TOTAL" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="DISCOUNT_PCT" NAME="DISCOUNT_PCT" PORTTYPE="INPUT" PRECISION="5" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="date/time" EXPRESSION="ORDER_DATE" NAME="ORDER_DATE" PORTTYPE="INPUT/OUTPUT" PRECISION="19" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" EXPRESSION="ORDER_STATUS" NAME="ORDER_STATUS" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" EXPRESSION="CHANNEL" NAME="CHANNEL" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
  </TRANSFORMATION>

  <!-- Aggregator: Sum orders by customer -->
  <TRANSFORMATION DESCRIPTION="Aggregate order totals by customer" NAME="AGG_BY_CUSTOMER" OBJECTVERSION="1" REUSABLE="NO" TYPE="Aggregator" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="CUSTOMER_ID" NAME="CUSTOMER_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0">
      <TABLEATTRIBUTE NAME="Group By" VALUE="YES"/>
    </TRANSFORMFIELD>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="COUNT(ORDER_ID)" NAME="TOTAL_ORDERS" PORTTYPE="OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="SUM(LINE_TOTAL)" NAME="TOTAL_REVENUE" PORTTYPE="OUTPUT" PRECISION="18" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="AVG(LINE_TOTAL)" NAME="AVG_ORDER_VALUE" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="ORDER_ID" NAME="ORDER_ID" PORTTYPE="INPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="LINE_TOTAL" NAME="LINE_TOTAL" PORTTYPE="INPUT" PRECISION="15" SCALE="2"/>
    <TABLEATTRIBUTE NAME="Tracing Level" VALUE="Normal"/>
    <TABLEATTRIBUTE NAME="Sorted Input" VALUE="NO"/>
  </TRANSFORMATION>

  <!-- Connectors -->
  <CONNECTOR FROMFIELD="PRODUCT_ID" FROMINSTANCE="SQ_ORDERS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="IN_PRODUCT_ID" TOINSTANCE="LKP_PRODUCTS" TOINSTANCETYPE="Lookup Procedure"/>

  <CONNECTOR FROMFIELD="ORDER_ID" FROMINSTANCE="SQ_ORDERS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="ORDER_ID" TOINSTANCE="EXP_CALC_TOTAL" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="CUSTOMER_ID" FROMINSTANCE="SQ_ORDERS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="CUSTOMER_ID" TOINSTANCE="EXP_CALC_TOTAL" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="QUANTITY" FROMINSTANCE="SQ_ORDERS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="QUANTITY" TOINSTANCE="EXP_CALC_TOTAL" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="UNIT_PRICE" FROMINSTANCE="SQ_ORDERS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="UNIT_PRICE" TOINSTANCE="EXP_CALC_TOTAL" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="DISCOUNT_PCT" FROMINSTANCE="SQ_ORDERS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="DISCOUNT_PCT" TOINSTANCE="EXP_CALC_TOTAL" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="ORDER_DATE" FROMINSTANCE="SQ_ORDERS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="ORDER_DATE" TOINSTANCE="EXP_CALC_TOTAL" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="ORDER_STATUS" FROMINSTANCE="SQ_ORDERS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="ORDER_STATUS" TOINSTANCE="EXP_CALC_TOTAL" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="CHANNEL" FROMINSTANCE="SQ_ORDERS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="CHANNEL" TOINSTANCE="EXP_CALC_TOTAL" TOINSTANCETYPE="Expression"/>

  <CONNECTOR FROMFIELD="PRODUCT_NAME" FROMINSTANCE="LKP_PRODUCTS" FROMINSTANCETYPE="Lookup Procedure" TOFIELD="PRODUCT_NAME" TOINSTANCE="EXP_CALC_TOTAL" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="CATEGORY" FROMINSTANCE="LKP_PRODUCTS" FROMINSTANCETYPE="Lookup Procedure" TOFIELD="CATEGORY" TOINSTANCE="EXP_CALC_TOTAL" TOINSTANCETYPE="Expression"/>

  <!-- EXP → FACT_ORDERS target -->
  <CONNECTOR FROMFIELD="ORDER_ID" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="ORDER_ID" TOINSTANCE="FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="CUSTOMER_ID" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="CUSTOMER_ID" TOINSTANCE="FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="PRODUCT_NAME" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="PRODUCT_NAME" TOINSTANCE="FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="CATEGORY" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="CATEGORY" TOINSTANCE="FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="QUANTITY" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="QUANTITY" TOINSTANCE="FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="UNIT_PRICE" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="UNIT_PRICE" TOINSTANCE="FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="LINE_TOTAL" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="LINE_TOTAL" TOINSTANCE="FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="ORDER_DATE" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="ORDER_DATE" TOINSTANCE="FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="ORDER_STATUS" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="ORDER_STATUS" TOINSTANCE="FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="CHANNEL" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="CHANNEL" TOINSTANCE="FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>

  <!-- EXP → AGG → AGG_ORDERS_BY_CUSTOMER target -->
  <CONNECTOR FROMFIELD="CUSTOMER_ID" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="CUSTOMER_ID" TOINSTANCE="AGG_BY_CUSTOMER" TOINSTANCETYPE="Aggregator"/>
  <CONNECTOR FROMFIELD="ORDER_ID" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="ORDER_ID" TOINSTANCE="AGG_BY_CUSTOMER" TOINSTANCETYPE="Aggregator"/>
  <CONNECTOR FROMFIELD="LINE_TOTAL" FROMINSTANCE="EXP_CALC_TOTAL" FROMINSTANCETYPE="Expression" TOFIELD="LINE_TOTAL" TOINSTANCE="AGG_BY_CUSTOMER" TOINSTANCETYPE="Aggregator"/>

  <CONNECTOR FROMFIELD="CUSTOMER_ID" FROMINSTANCE="AGG_BY_CUSTOMER" FROMINSTANCETYPE="Aggregator" TOFIELD="CUSTOMER_ID" TOINSTANCE="AGG_ORDERS_BY_CUSTOMER" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="TOTAL_ORDERS" FROMINSTANCE="AGG_BY_CUSTOMER" FROMINSTANCETYPE="Aggregator" TOFIELD="TOTAL_ORDERS" TOINSTANCE="AGG_ORDERS_BY_CUSTOMER" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="TOTAL_REVENUE" FROMINSTANCE="AGG_BY_CUSTOMER" FROMINSTANCETYPE="Aggregator" TOFIELD="TOTAL_REVENUE" TOINSTANCE="AGG_ORDERS_BY_CUSTOMER" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="AVG_ORDER_VALUE" FROMINSTANCE="AGG_BY_CUSTOMER" FROMINSTANCETYPE="Aggregator" TOFIELD="AVG_ORDER_VALUE" TOINSTANCE="AGG_ORDERS_BY_CUSTOMER" TOINSTANCETYPE="Target Definition"/>

  <TARGETLOADORDER ORDER="1" TARGETINSTANCE="FACT_ORDERS"/>
  <TARGETLOADORDER ORDER="2" TARGETINSTANCE="AGG_ORDERS_BY_CUSTOMER"/>

</MAPPING>

</FOLDER>
</REPOSITORY>
</POWERMART>

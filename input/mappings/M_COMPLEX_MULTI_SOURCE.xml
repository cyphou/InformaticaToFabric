<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE POWERMART SYSTEM "powrmart.dtd">
<POWERMART CREATION_DATE="03/23/2026 10:00:00" REPOSITORY_VERSION="186.90">
<REPOSITORY NAME="PROD_REPO" VERSION="186" DATABASETYPE="Oracle">
<FOLDER NAME="ADVANCED_ETL" GROUP="" OWNER="admin" SHARED="NOTSHARED" DESCRIPTION="Advanced ETL with Mapplets, Router, SQL Transformation, Rank, Normalizer">

<!-- ===================================================================== -->
<!-- MAPPING: M_COMPLEX_MULTI_SOURCE                                        -->
<!-- Complex — 2 sources + Mapplet + Router + SQL Transformation +          -->
<!--           Rank + Normalizer + Lookup w/ SQL Override + 3 targets       -->
<!-- ===================================================================== -->

<!-- Source: TRANSACTIONS -->
<SOURCE BUSINESSNAME="" DATABASETYPE="Oracle" DBDNAME="ORACLE_PROD" DESCRIPTION="Transaction events" NAME="TRANSACTIONS" OBJECTVERSION="1" OWNERNAME="FINANCE" VERSIONNUMBER="1">
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="1" NAME="TXN_ID" NULLABLE="NOTNULL" PRECISION="15" SCALE="0"/>
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="2" NAME="ACCOUNT_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <SOURCEFIELD DATATYPE="varchar2" FIELDNUMBER="3" NAME="TXN_TYPE" NULLABLE="NULL" PRECISION="20" SCALE="0"/>
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="4" NAME="AMOUNT" NULLABLE="NULL" PRECISION="15" SCALE="2"/>
  <SOURCEFIELD DATATYPE="varchar2" FIELDNUMBER="5" NAME="CURRENCY" NULLABLE="NULL" PRECISION="3" SCALE="0"/>
  <SOURCEFIELD DATATYPE="date" FIELDNUMBER="6" NAME="TXN_DATE" NULLABLE="NULL" PRECISION="19" SCALE="0"/>
  <SOURCEFIELD DATATYPE="varchar2" FIELDNUMBER="7" NAME="STATUS" NULLABLE="NULL" PRECISION="20" SCALE="0"/>
  <SOURCEFIELD DATATYPE="varchar2" FIELDNUMBER="8" NAME="CHANNEL" NULLABLE="NULL" PRECISION="30" SCALE="0"/>
  <SOURCEFIELD DATATYPE="varchar2" FIELDNUMBER="9" NAME="TAGS" NULLABLE="NULL" PRECISION="500" SCALE="0"/>
</SOURCE>

<!-- Source: ACCOUNTS (second source for Joiner) -->
<SOURCE BUSINESSNAME="" DATABASETYPE="Oracle" DBDNAME="ORACLE_PROD" DESCRIPTION="Account master" NAME="ACCOUNTS" OBJECTVERSION="1" OWNERNAME="FINANCE" VERSIONNUMBER="1">
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="1" NAME="ACCOUNT_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <SOURCEFIELD DATATYPE="varchar2" FIELDNUMBER="2" NAME="ACCOUNT_NAME" NULLABLE="NULL" PRECISION="200" SCALE="0"/>
  <SOURCEFIELD DATATYPE="varchar2" FIELDNUMBER="3" NAME="ACCOUNT_TYPE" NULLABLE="NULL" PRECISION="30" SCALE="0"/>
  <SOURCEFIELD DATATYPE="varchar2" FIELDNUMBER="4" NAME="REGION" NULLABLE="NULL" PRECISION="50" SCALE="0"/>
  <SOURCEFIELD DATATYPE="varchar2" FIELDNUMBER="5" NAME="RISK_LEVEL" NULLABLE="NULL" PRECISION="10" SCALE="0"/>
</SOURCE>

<!-- Target: FACT_TRANSACTIONS_HIGH -->
<TARGET BUSINESSNAME="" DATABASETYPE="Oracle" DESCRIPTION="High-value transactions" NAME="FACT_TXN_HIGH" OBJECTVERSION="1">
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="1" KEYTYPE="PRIMARY KEY" NAME="TXN_ID" NULLABLE="NOTNULL" PRECISION="15" SCALE="0"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="2" KEYTYPE="NOT A KEY" NAME="ACCOUNT_NAME" NULLABLE="NULL" PRECISION="200" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="3" KEYTYPE="NOT A KEY" NAME="AMOUNT_USD" NULLABLE="NULL" PRECISION="15" SCALE="2"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="4" KEYTYPE="NOT A KEY" NAME="RISK_CATEGORY" NULLABLE="NULL" PRECISION="20" SCALE="0"/>
  <TARGETFIELD DATATYPE="date" FIELDNUMBER="5" KEYTYPE="NOT A KEY" NAME="TXN_DATE" NULLABLE="NULL" PRECISION="19" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="6" KEYTYPE="NOT A KEY" NAME="TXN_RANK" NULLABLE="NULL" PRECISION="10" SCALE="0"/>
</TARGET>

<!-- Target: FACT_TRANSACTIONS_LOW -->
<TARGET BUSINESSNAME="" DATABASETYPE="Oracle" DESCRIPTION="Low-value transactions" NAME="FACT_TXN_LOW" OBJECTVERSION="1">
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="1" KEYTYPE="PRIMARY KEY" NAME="TXN_ID" NULLABLE="NOTNULL" PRECISION="15" SCALE="0"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="2" KEYTYPE="NOT A KEY" NAME="ACCOUNT_NAME" NULLABLE="NULL" PRECISION="200" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="3" KEYTYPE="NOT A KEY" NAME="AMOUNT_USD" NULLABLE="NULL" PRECISION="15" SCALE="2"/>
  <TARGETFIELD DATATYPE="date" FIELDNUMBER="4" KEYTYPE="NOT A KEY" NAME="TXN_DATE" NULLABLE="NULL" PRECISION="19" SCALE="0"/>
</TARGET>

<!-- Target: FACT_TXN_TAGS_NORMALIZED -->
<TARGET BUSINESSNAME="" DATABASETYPE="Oracle" DESCRIPTION="Normalized transaction tags" NAME="FACT_TXN_TAGS" OBJECTVERSION="1">
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="1" KEYTYPE="NOT A KEY" NAME="TXN_ID" NULLABLE="NOTNULL" PRECISION="15" SCALE="0"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="2" KEYTYPE="NOT A KEY" NAME="TAG_VALUE" NULLABLE="NULL" PRECISION="100" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="3" KEYTYPE="NOT A KEY" NAME="TAG_INDEX" NULLABLE="NULL" PRECISION="5" SCALE="0"/>
</TARGET>

<!-- Reusable Mapplet: MPLT_CURRENCY_CONVERT -->
<MAPPLET DESCRIPTION="Reusable currency conversion mapplet" ISVALID="YES" NAME="MPLT_CURRENCY_CONVERT" OBJECTVERSION="1" VERSIONNUMBER="1">
  <TRANSFORMATION DESCRIPTION="Convert amount to USD" NAME="EXP_CONVERT_USD" OBJECTVERSION="1" REUSABLE="NO" TYPE="Expression" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="AMOUNT" NAME="IN_AMOUNT" PORTTYPE="INPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="string" EXPRESSION="CURRENCY" NAME="IN_CURRENCY" PORTTYPE="INPUT" PRECISION="3" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="IIF(IN_CURRENCY = 'USD', IN_AMOUNT, IIF(IN_CURRENCY = 'EUR', IN_AMOUNT * 1.08, IIF(IN_CURRENCY = 'GBP', IN_AMOUNT * 1.27, IIF(IN_CURRENCY = 'JPY', IN_AMOUNT * 0.0067, IN_AMOUNT))))" NAME="AMOUNT_USD" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="string" EXPRESSION="IIF(IN_CURRENCY = 'USD', 'USD', 'CONVERTED')" NAME="CONVERSION_FLAG" PORTTYPE="OUTPUT" PRECISION="10" SCALE="0"/>
  </TRANSFORMATION>
</MAPPLET>

<!-- Mapping Definition -->
<MAPPING DESCRIPTION="Complex multi-source with Mapplet, Router, SQL Transformation, Rank, and Normalizer" ISVALID="YES" NAME="M_COMPLEX_MULTI_SOURCE" OBJECTVERSION="1" VERSIONNUMBER="1">

  <!-- Source Qualifier: Transactions -->
  <TRANSFORMATION DESCRIPTION="Read transactions" NAME="SQ_TRANSACTIONS" OBJECTVERSION="1" REUSABLE="NO" TYPE="Source Qualifier" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="TXN_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="ACCOUNT_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="TXN_TYPE" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="AMOUNT" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="CURRENCY" PORTTYPE="INPUT/OUTPUT" PRECISION="3" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="TXN_DATE" PORTTYPE="INPUT/OUTPUT" PRECISION="19" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="STATUS" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="CHANNEL" PORTTYPE="INPUT/OUTPUT" PRECISION="30" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="TAGS" PORTTYPE="INPUT/OUTPUT" PRECISION="500" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT TXN_ID, ACCOUNT_ID, TXN_TYPE, AMOUNT, CURRENCY, TXN_DATE, DECODE(STATUS, 'C', 'COMPLETED', 'P', 'PENDING', 'F', 'FAILED', STATUS) AS STATUS, NVL(CHANNEL, 'UNKNOWN') AS CHANNEL, TAGS FROM FINANCE.TRANSACTIONS WHERE TXN_DATE >= ADD_MONTHS(SYSDATE, -3)"/>
    <TABLEATTRIBUTE NAME="Source Filter" VALUE="STATUS != 'X'"/>
  </TRANSFORMATION>

  <!-- Source Qualifier: Accounts -->
  <TRANSFORMATION DESCRIPTION="Read accounts" NAME="SQ_ACCOUNTS" OBJECTVERSION="1" REUSABLE="NO" TYPE="Source Qualifier" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="ACCOUNT_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="ACCOUNT_NAME" PORTTYPE="INPUT/OUTPUT" PRECISION="200" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="ACCOUNT_TYPE" PORTTYPE="INPUT/OUTPUT" PRECISION="30" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="REGION" PORTTYPE="INPUT/OUTPUT" PRECISION="50" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="RISK_LEVEL" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Sql Query" VALUE=""/>
  </TRANSFORMATION>

  <!-- Joiner: Transactions + Accounts -->
  <TRANSFORMATION DESCRIPTION="Join transactions with account master" NAME="JNR_TXN_ACCT" OBJECTVERSION="1" REUSABLE="NO" TYPE="Joiner" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="TXN_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="ACCOUNT_ID_M" PORTTYPE="INPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="TXN_TYPE" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="AMOUNT" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="CURRENCY" PORTTYPE="INPUT/OUTPUT" PRECISION="3" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="TXN_DATE" PORTTYPE="INPUT/OUTPUT" PRECISION="19" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="STATUS" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="CHANNEL" PORTTYPE="INPUT/OUTPUT" PRECISION="30" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="TAGS" PORTTYPE="INPUT/OUTPUT" PRECISION="500" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="ACCOUNT_ID_D" PORTTYPE="INPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="ACCOUNT_NAME" PORTTYPE="INPUT/OUTPUT" PRECISION="200" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="ACCOUNT_TYPE" PORTTYPE="INPUT/OUTPUT" PRECISION="30" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="REGION" PORTTYPE="INPUT/OUTPUT" PRECISION="50" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="RISK_LEVEL" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Join Type" VALUE="Normal Join"/>
    <TABLEATTRIBUTE NAME="Join Condition" VALUE="ACCOUNT_ID_M = ACCOUNT_ID_D"/>
    <TABLEATTRIBUTE NAME="Sorted Input" VALUE="NO"/>
  </TRANSFORMATION>

  <!-- Mapplet Instance: Currency Conversion -->
  <TRANSFORMATION DESCRIPTION="Reusable currency converter" NAME="MPLT_CURRENCY_CONVERT" OBJECTVERSION="1" REUSABLE="YES" TYPE="Mapplet" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="IN_AMOUNT" PORTTYPE="INPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="IN_CURRENCY" PORTTYPE="INPUT" PRECISION="3" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="AMOUNT_USD" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="CONVERSION_FLAG" PORTTYPE="OUTPUT" PRECISION="10" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Mapplet" VALUE="MPLT_CURRENCY_CONVERT"/>
  </TRANSFORMATION>

  <!-- SQL Transformation: Compute risk score via dynamic SQL -->
  <TRANSFORMATION DESCRIPTION="Dynamic SQL risk scoring" NAME="SQLT_RISK_SCORE" OBJECTVERSION="1" REUSABLE="NO" TYPE="SQL Transformation" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="IN_AMOUNT_USD" PORTTYPE="INPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="IN_RISK_LEVEL" PORTTYPE="INPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="IN_TXN_TYPE" PORTTYPE="INPUT" PRECISION="20" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="RISK_CATEGORY" PORTTYPE="OUTPUT" PRECISION="20" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="RISK_SCORE" PORTTYPE="OUTPUT" PRECISION="5" SCALE="2"/>
    <TABLEATTRIBUTE NAME="SQL Query" VALUE="SELECT CASE WHEN :IN_AMOUNT_USD > 10000 AND :IN_RISK_LEVEL = 'HIGH' THEN 'CRITICAL' WHEN :IN_AMOUNT_USD > 10000 THEN 'ELEVATED' WHEN :IN_RISK_LEVEL = 'HIGH' THEN 'WATCH' ELSE 'NORMAL' END AS RISK_CATEGORY, CASE WHEN :IN_TXN_TYPE = 'WIRE' THEN :IN_AMOUNT_USD * 0.02 ELSE :IN_AMOUNT_USD * 0.005 END AS RISK_SCORE FROM DUAL"/>
    <TABLEATTRIBUTE NAME="Connection Information" VALUE="ORACLE_PROD"/>
    <TABLEATTRIBUTE NAME="SQL Mode" VALUE="Query"/>
  </TRANSFORMATION>

  <!-- Lookup: Fraud blacklist with SQL Override -->
  <TRANSFORMATION DESCRIPTION="Check fraud blacklist" NAME="LKP_FRAUD_BLACKLIST" OBJECTVERSION="1" REUSABLE="NO" TYPE="Lookup Procedure" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="IN_ACCOUNT_ID" PORTTYPE="INPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="BLOCKED_ACCOUNT_ID" PORTTYPE="OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="BLOCK_REASON" PORTTYPE="OUTPUT" PRECISION="200" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Lookup table name" VALUE="COMPLIANCE.FRAUD_BLACKLIST"/>
    <TABLEATTRIBUTE NAME="Lookup Sql Override" VALUE="SELECT ACCOUNT_ID AS BLOCKED_ACCOUNT_ID, NVL(REASON, 'Unspecified') AS BLOCK_REASON FROM COMPLIANCE.FRAUD_BLACKLIST WHERE ACTIVE_FLAG = 'Y' AND EXPIRY_DATE > SYSDATE"/>
    <TABLEATTRIBUTE NAME="Lookup condition" VALUE="IN_ACCOUNT_ID = BLOCKED_ACCOUNT_ID"/>
    <TABLEATTRIBUTE NAME="Connection Information" VALUE="ORACLE_PROD"/>
  </TRANSFORMATION>

  <!-- Router: Split by amount threshold -->
  <TRANSFORMATION DESCRIPTION="Route transactions by value tier" NAME="RTR_VALUE_TIER" OBJECTVERSION="1" REUSABLE="NO" TYPE="Router" VERSIONNUMBER="1">
    <!-- Input group -->
    <TRANSFORMFIELD DATATYPE="number" NAME="TXN_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="0" GROUP="INPUT"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="ACCOUNT_NAME" PORTTYPE="INPUT/OUTPUT" PRECISION="200" SCALE="0" GROUP="INPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="AMOUNT_USD" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2" GROUP="INPUT"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="RISK_CATEGORY" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0" GROUP="INPUT"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="TXN_DATE" PORTTYPE="INPUT/OUTPUT" PRECISION="19" SCALE="0" GROUP="INPUT"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="TAGS" PORTTYPE="INPUT/OUTPUT" PRECISION="500" SCALE="0" GROUP="INPUT"/>
    <!-- Output group: HIGH_VALUE (amount >= 5000) -->
    <TRANSFORMFIELD DATATYPE="number" NAME="TXN_ID1" PORTTYPE="OUTPUT" PRECISION="15" SCALE="0" GROUP="HIGH_VALUE"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="ACCOUNT_NAME1" PORTTYPE="OUTPUT" PRECISION="200" SCALE="0" GROUP="HIGH_VALUE"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="AMOUNT_USD1" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2" GROUP="HIGH_VALUE"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="RISK_CATEGORY1" PORTTYPE="OUTPUT" PRECISION="20" SCALE="0" GROUP="HIGH_VALUE"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="TXN_DATE1" PORTTYPE="OUTPUT" PRECISION="19" SCALE="0" GROUP="HIGH_VALUE"/>
    <!-- Output group: LOW_VALUE (default — amount < 5000) -->
    <TRANSFORMFIELD DATATYPE="number" NAME="TXN_ID2" PORTTYPE="OUTPUT" PRECISION="15" SCALE="0" GROUP="LOW_VALUE"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="ACCOUNT_NAME2" PORTTYPE="OUTPUT" PRECISION="200" SCALE="0" GROUP="LOW_VALUE"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="AMOUNT_USD2" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2" GROUP="LOW_VALUE"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="TXN_DATE2" PORTTYPE="OUTPUT" PRECISION="19" SCALE="0" GROUP="LOW_VALUE"/>
    <TABLEATTRIBUTE NAME="Router Group" VALUE="HIGH_VALUE"/>
    <TABLEATTRIBUTE NAME="Router Group Condition" VALUE="AMOUNT_USD >= 5000"/>
    <TABLEATTRIBUTE NAME="Router Group" VALUE="LOW_VALUE"/>
    <TABLEATTRIBUTE NAME="Router Group Condition" VALUE="TRUE"/>
  </TRANSFORMATION>

  <!-- Rank: Top N transactions per account (for high-value path) -->
  <TRANSFORMATION DESCRIPTION="Top 10 transactions per account" NAME="RNK_TOP_TXN" OBJECTVERSION="1" REUSABLE="NO" TYPE="Rank" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="TXN_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="ACCOUNT_NAME" PORTTYPE="INPUT/OUTPUT" PRECISION="200" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="AMOUNT_USD" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="RISK_CATEGORY" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="TXN_DATE" PORTTYPE="INPUT/OUTPUT" PRECISION="19" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="TXN_RANK" PORTTYPE="OUTPUT" PRECISION="10" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Top/Bottom" VALUE="Top"/>
    <TABLEATTRIBUTE NAME="Number of Ranks" VALUE="10"/>
    <TABLEATTRIBUTE NAME="Rank Data Port" VALUE="AMOUNT_USD"/>
    <TABLEATTRIBUTE NAME="Group By Port" VALUE="ACCOUNT_NAME"/>
  </TRANSFORMATION>

  <!-- Normalizer: Split pipe-delimited TAGS into rows (for low-value path) -->
  <TRANSFORMATION DESCRIPTION="Normalize pipe-delimited tags" NAME="NRM_TAGS" OBJECTVERSION="1" REUSABLE="NO" TYPE="Normalizer" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="TXN_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="TAGS" PORTTYPE="INPUT" PRECISION="500" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="TAG_VALUE" PORTTYPE="OUTPUT" PRECISION="100" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="TAG_INDEX" PORTTYPE="OUTPUT" PRECISION="5" SCALE="0"/>
    <TABLEATTRIBUTE NAME="OCCURS" VALUE="10"/>
    <TABLEATTRIBUTE NAME="Delimiter" VALUE="|"/>
  </TRANSFORMATION>

  <!-- =================== CONNECTORS =================== -->

  <!-- SQ_TRANSACTIONS → JNR (Master) -->
  <CONNECTOR FROMFIELD="TXN_ID" FROMINSTANCE="SQ_TRANSACTIONS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="TXN_ID" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>
  <CONNECTOR FROMFIELD="ACCOUNT_ID" FROMINSTANCE="SQ_TRANSACTIONS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="ACCOUNT_ID_M" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>
  <CONNECTOR FROMFIELD="TXN_TYPE" FROMINSTANCE="SQ_TRANSACTIONS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="TXN_TYPE" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>
  <CONNECTOR FROMFIELD="AMOUNT" FROMINSTANCE="SQ_TRANSACTIONS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="AMOUNT" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>
  <CONNECTOR FROMFIELD="CURRENCY" FROMINSTANCE="SQ_TRANSACTIONS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="CURRENCY" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>
  <CONNECTOR FROMFIELD="TXN_DATE" FROMINSTANCE="SQ_TRANSACTIONS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="TXN_DATE" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>
  <CONNECTOR FROMFIELD="STATUS" FROMINSTANCE="SQ_TRANSACTIONS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="STATUS" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>
  <CONNECTOR FROMFIELD="CHANNEL" FROMINSTANCE="SQ_TRANSACTIONS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="CHANNEL" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>
  <CONNECTOR FROMFIELD="TAGS" FROMINSTANCE="SQ_TRANSACTIONS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="TAGS" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>

  <!-- SQ_ACCOUNTS → JNR (Detail) -->
  <CONNECTOR FROMFIELD="ACCOUNT_ID" FROMINSTANCE="SQ_ACCOUNTS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="ACCOUNT_ID_D" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>
  <CONNECTOR FROMFIELD="ACCOUNT_NAME" FROMINSTANCE="SQ_ACCOUNTS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="ACCOUNT_NAME" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>
  <CONNECTOR FROMFIELD="ACCOUNT_TYPE" FROMINSTANCE="SQ_ACCOUNTS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="ACCOUNT_TYPE" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>
  <CONNECTOR FROMFIELD="REGION" FROMINSTANCE="SQ_ACCOUNTS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="REGION" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>
  <CONNECTOR FROMFIELD="RISK_LEVEL" FROMINSTANCE="SQ_ACCOUNTS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="RISK_LEVEL" TOINSTANCE="JNR_TXN_ACCT" TOINSTANCETYPE="Joiner"/>

  <!-- JNR → Mapplet (currency conversion) -->
  <CONNECTOR FROMFIELD="AMOUNT" FROMINSTANCE="JNR_TXN_ACCT" FROMINSTANCETYPE="Joiner" TOFIELD="IN_AMOUNT" TOINSTANCE="MPLT_CURRENCY_CONVERT" TOINSTANCETYPE="Mapplet"/>
  <CONNECTOR FROMFIELD="CURRENCY" FROMINSTANCE="JNR_TXN_ACCT" FROMINSTANCETYPE="Joiner" TOFIELD="IN_CURRENCY" TOINSTANCE="MPLT_CURRENCY_CONVERT" TOINSTANCETYPE="Mapplet"/>

  <!-- JNR → LKP Fraud Blacklist -->
  <CONNECTOR FROMFIELD="ACCOUNT_ID_M" FROMINSTANCE="JNR_TXN_ACCT" FROMINSTANCETYPE="Joiner" TOFIELD="IN_ACCOUNT_ID" TOINSTANCE="LKP_FRAUD_BLACKLIST" TOINSTANCETYPE="Lookup Procedure"/>

  <!-- Mapplet + JNR → SQL Transformation -->
  <CONNECTOR FROMFIELD="AMOUNT_USD" FROMINSTANCE="MPLT_CURRENCY_CONVERT" FROMINSTANCETYPE="Mapplet" TOFIELD="IN_AMOUNT_USD" TOINSTANCE="SQLT_RISK_SCORE" TOINSTANCETYPE="SQL Transformation"/>
  <CONNECTOR FROMFIELD="RISK_LEVEL" FROMINSTANCE="JNR_TXN_ACCT" FROMINSTANCETYPE="Joiner" TOFIELD="IN_RISK_LEVEL" TOINSTANCE="SQLT_RISK_SCORE" TOINSTANCETYPE="SQL Transformation"/>
  <CONNECTOR FROMFIELD="TXN_TYPE" FROMINSTANCE="JNR_TXN_ACCT" FROMINSTANCETYPE="Joiner" TOFIELD="IN_TXN_TYPE" TOINSTANCE="SQLT_RISK_SCORE" TOINSTANCETYPE="SQL Transformation"/>

  <!-- JNR + Mapplet + SQLT → Router -->
  <CONNECTOR FROMFIELD="TXN_ID" FROMINSTANCE="JNR_TXN_ACCT" FROMINSTANCETYPE="Joiner" TOFIELD="TXN_ID" TOINSTANCE="RTR_VALUE_TIER" TOINSTANCETYPE="Router"/>
  <CONNECTOR FROMFIELD="ACCOUNT_NAME" FROMINSTANCE="JNR_TXN_ACCT" FROMINSTANCETYPE="Joiner" TOFIELD="ACCOUNT_NAME" TOINSTANCE="RTR_VALUE_TIER" TOINSTANCETYPE="Router"/>
  <CONNECTOR FROMFIELD="AMOUNT_USD" FROMINSTANCE="MPLT_CURRENCY_CONVERT" FROMINSTANCETYPE="Mapplet" TOFIELD="AMOUNT_USD" TOINSTANCE="RTR_VALUE_TIER" TOINSTANCETYPE="Router"/>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE POWERMART SYSTEM "powrmart.dtd">
<POWERMART CREATION_DATE="03/23/2026 14:00:00" REPOSITORY_VERSION="186.90">
<REPOSITORY NAME="PROD_REPO" VERSION="186" DATABASETYPE="Oracle">
<FOLDER NAME="HR_ETL" GROUP="" OWNER="admin" SHARED="NOTSHARED" DESCRIPTION="HR ETL Mappings with Mapplets">

<!-- ================================================================ -->
<!-- MAPPLET: MPLT_COMMON_DERIVE — Reusable name + audit derivation   -->
<!-- ================================================================ -->
<MAPPLET DESCRIPTION="Common derivation logic for name and audit columns" NAME="MPLT_COMMON_DERIVE" OBJECTVERSION="1" VERSIONNUMBER="1">
  <TRANSFORMATION DESCRIPTION="Concatenate first + last name, derive audit cols" NAME="EXP_DERIVE_NAME" OBJECTVERSION="1" REUSABLE="NO" TYPE="Expression" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="string" EXPRESSION="FIRST_NAME" NAME="FIRST_NAME" PORTTYPE="INPUT" PRECISION="100" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" EXPRESSION="LAST_NAME" NAME="LAST_NAME" PORTTYPE="INPUT" PRECISION="100" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" EXPRESSION="FIRST_NAME || ' ' || LAST_NAME" NAME="FULL_NAME" PORTTYPE="OUTPUT" PRECISION="201" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="date/time" EXPRESSION="SYSDATE" NAME="ETL_LOAD_DATE" PORTTYPE="OUTPUT" PRECISION="19" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" EXPRESSION="'INFA_BATCH'" NAME="ETL_SOURCE_SYSTEM" PORTTYPE="OUTPUT" PRECISION="50" SCALE="0"/>
  </TRANSFORMATION>
  <TRANSFORMATION DESCRIPTION="Strip invalid email records" NAME="FIL_VALID_EMAIL" OBJECTVERSION="1" REUSABLE="NO" TYPE="Filter" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="string" NAME="FULL_NAME" PORTTYPE="INPUT/OUTPUT" PRECISION="201" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="EMAIL" PORTTYPE="INPUT/OUTPUT" PRECISION="250" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="ETL_LOAD_DATE" PORTTYPE="INPUT/OUTPUT" PRECISION="19" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="ETL_SOURCE_SYSTEM" PORTTYPE="INPUT/OUTPUT" PRECISION="50" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Filter Condition" VALUE="NOT IS_SPACES(EMAIL) AND EMAIL IS NOT NULL"/>
  </TRANSFORMATION>
</MAPPLET>

<!-- ================================================================ -->
<!-- MAPPLET: MPLT_SALARY_CALC — Reusable salary + tax computation    -->
<!-- ================================================================ -->
<MAPPLET DESCRIPTION="Calculates annual salary, tax, and net pay" NAME="MPLT_SALARY_CALC" OBJECTVERSION="1" VERSIONNUMBER="1">
  <TRANSFORMATION DESCRIPTION="Calculate annual salary and tax" NAME="EXP_SALARY" OBJECTVERSION="1" REUSABLE="NO" TYPE="Expression" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="MONTHLY_SALARY" NAME="MONTHLY_SALARY" PORTTYPE="INPUT" PRECISION="12" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="MONTHLY_SALARY * 12" NAME="ANNUAL_SALARY" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="IIF(MONTHLY_SALARY * 12 > 50000, MONTHLY_SALARY * 12 * 0.30, MONTHLY_SALARY * 12 * 0.20)" NAME="TAX_AMOUNT" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="MONTHLY_SALARY * 12 - IIF(MONTHLY_SALARY * 12 > 50000, MONTHLY_SALARY * 12 * 0.30, MONTHLY_SALARY * 12 * 0.20)" NAME="NET_PAY" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2"/>
  </TRANSFORMATION>
  <TRANSFORMATION DESCRIPTION="Sort by salary descending" NAME="SRT_BY_SALARY" OBJECTVERSION="1" REUSABLE="NO" TYPE="Sorter" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="ANNUAL_SALARY" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="TAX_AMOUNT" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="NET_PAY" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
    <TABLEATTRIBUTE NAME="Sorter Sort Order" VALUE="Descending"/>
    <TABLEATTRIBUTE NAME="Tracing Level" VALUE="Normal"/>
    <TABLEATTRIBUTE NAME="Distinct" VALUE="NO"/>
  </TRANSFORMATION>
</MAPPLET>

<!-- Source Table: EMPLOYEES -->
<SOURCE BUSINESSNAME="" DATABASETYPE="Oracle" DBDNAME="ORACLE_PROD" DESCRIPTION="Employee master table" NAME="EMPLOYEES" OBJECTVERSION="1" OWNERNAME="HR" VERSIONNUMBER="1">
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="1" NAME="EMPLOYEE_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <SOURCEFIELD DATATYPE="varchar2" FIELDNUMBER="2" NAME="FIRST_NAME" NULLABLE="NULL" PRECISION="100" SCALE="0"/>

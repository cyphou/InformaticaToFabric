  <SOURCEFIELD DATATYPE="varchar2" FIELDNUMBER="5" NAME="DEPARTMENT" NULLABLE="NULL" PRECISION="50" SCALE="0"/>
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="6" NAME="MONTHLY_SALARY" NULLABLE="NULL" PRECISION="12" SCALE="2"/>
  <SOURCEFIELD DATATYPE="date" FIELDNUMBER="7" NAME="HIRE_DATE" NULLABLE="NULL" PRECISION="19" SCALE="0"/>

<!-- ================================================================ -->
<!-- MAPPING: M_LOAD_EMPLOYEES (Complex — uses 2 Mapplets + LKP)     -->
<!-- ================================================================ -->
<MAPPING DESCRIPTION="Load employees with reusable Mapplet derivations and salary calculation" ISVALID="YES" NAME="M_LOAD_EMPLOYEES" OBJECTVERSION="1" VERSIONNUMBER="1">

  <!-- Source Qualifier -->
  <TRANSFORMATION DESCRIPTION="Read from EMPLOYEES" NAME="SQ_EMPLOYEES" OBJECTVERSION="1" REUSABLE="NO" TYPE="Source Qualifier" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="EMPLOYEE_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="FIRST_NAME" PORTTYPE="INPUT/OUTPUT" PRECISION="100" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="LAST_NAME" PORTTYPE="INPUT/OUTPUT" PRECISION="100" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="EMAIL" PORTTYPE="INPUT/OUTPUT" PRECISION="250" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="DEPARTMENT" PORTTYPE="INPUT/OUTPUT" PRECISION="50" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="MONTHLY_SALARY" PORTTYPE="INPUT/OUTPUT" PRECISION="12" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="HIRE_DATE" PORTTYPE="INPUT/OUTPUT" PRECISION="19" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="STATUS" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT EMPLOYEE_ID, FIRST_NAME, LAST_NAME, EMAIL, DEPARTMENT, MONTHLY_SALARY, HIRE_DATE, STATUS FROM HR.EMPLOYEES WHERE STATUS = 'ACTIVE' AND HIRE_DATE >= ADD_MONTHS(SYSDATE, -120)"/>
  </TRANSFORMATION>

  <!-- Mapplet Reference: Common name + audit derivation -->
  <TRANSFORMATION DESCRIPTION="Reusable name derivation" NAME="MPLT_COMMON_DERIVE" OBJECTVERSION="1" REUSABLE="YES" TYPE="Mapplet" VERSIONNUMBER="1">
    <TABLEATTRIBUTE NAME="Mapplet" VALUE="MPLT_COMMON_DERIVE"/>
  </TRANSFORMATION>

  <!-- Mapplet Reference: Salary calculation -->
  <TRANSFORMATION DESCRIPTION="Reusable salary computation" NAME="MPLT_SALARY_CALC" OBJECTVERSION="1" REUSABLE="YES" TYPE="Mapplet" VERSIONNUMBER="1">
    <TABLEATTRIBUTE NAME="Mapplet" VALUE="MPLT_SALARY_CALC"/>
  </TRANSFORMATION>

  <!-- Lookup: Department manager -->
  <TRANSFORMATION DESCRIPTION="Lookup department manager name" NAME="LKP_DEPT_MGR" OBJECTVERSION="1" REUSABLE="NO" TYPE="Lookup Procedure" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="string" NAME="IN_DEPARTMENT" PORTTYPE="INPUT" PRECISION="50" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="MANAGER_NAME" PORTTYPE="OUTPUT" PRECISION="200" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Lookup table name" VALUE="HR.DEPARTMENTS"/>
    <TABLEATTRIBUTE NAME="Lookup Sql Override" VALUE="SELECT DEPT_NAME, MANAGER_NAME FROM HR.DEPARTMENTS WHERE ACTIVE = 'Y'"/>
    <TABLEATTRIBUTE NAME="Lookup condition" VALUE="IN_DEPARTMENT = DEPT_NAME"/>
    <TABLEATTRIBUTE NAME="Connection Information" VALUE="ORACLE_HR"/>
  </TRANSFORMATION>

  <!-- SQL Transformation: Custom ranking query -->
  <TRANSFORMATION DESCRIPTION="Rank employees by salary within department using custom SQL" NAME="SQLT_RANK_BY_DEPT" OBJECTVERSION="1" REUSABLE="NO" TYPE="SQL Transformation" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="EMPLOYEE_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="DEPARTMENT" PORTTYPE="INPUT" PRECISION="50" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="ANNUAL_SALARY" PORTTYPE="INPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="DEPT_SALARY_RANK" PORTTYPE="OUTPUT" PRECISION="10" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT EMPLOYEE_ID, DENSE_RANK() OVER (PARTITION BY DEPARTMENT ORDER BY ANNUAL_SALARY DESC) AS DEPT_SALARY_RANK FROM HR.EMPLOYEES"/>
  </TRANSFORMATION>

  <!-- Connectors -->
  <CONNECTOR FROMFIELD="FIRST_NAME" FROMINSTANCE="SQ_EMPLOYEES" FROMINSTANCETYPE="Source Qualifier" TOFIELD="FIRST_NAME" TOINSTANCE="MPLT_COMMON_DERIVE" TOINSTANCETYPE="Mapplet"/>
  <CONNECTOR FROMFIELD="LAST_NAME" FROMINSTANCE="SQ_EMPLOYEES" FROMINSTANCETYPE="Source Qualifier" TOFIELD="LAST_NAME" TOINSTANCE="MPLT_COMMON_DERIVE" TOINSTANCETYPE="Mapplet"/>
  <CONNECTOR FROMFIELD="MONTHLY_SALARY" FROMINSTANCE="SQ_EMPLOYEES" FROMINSTANCETYPE="Source Qualifier" TOFIELD="MONTHLY_SALARY" TOINSTANCE="MPLT_SALARY_CALC" TOINSTANCETYPE="Mapplet"/>
  <CONNECTOR FROMFIELD="DEPARTMENT" FROMINSTANCE="SQ_EMPLOYEES" FROMINSTANCETYPE="Source Qualifier" TOFIELD="IN_DEPARTMENT" TOINSTANCE="LKP_DEPT_MGR" TOINSTANCETYPE="Lookup Procedure"/>

  <TARGETLOADORDER TARGETINSTANCE="DIM_EMPLOYEE" ORDER="1"/>
</MAPPING>

</FOLDER>
</REPOSITORY>

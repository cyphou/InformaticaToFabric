<!DOCTYPE POWERMART SYSTEM "powrmart.dtd">
<POWERMART CREATION_DATE="03/23/2026 10:00:00" REPOSITORY_VERSION="186.90">
<REPOSITORY NAME="PROD_REPO" VERSION="186" DATABASETYPE="Oracle">
<FOLDER NAME="SALES_ETL" GROUP="" OWNER="admin" SHARED="NOTSHARED" DESCRIPTION="Sales ETL Mappings">

<!-- ============================================================ -->
<!-- MAPPING: M_UPSERT_INVENTORY (Complex — SQ → UPD → TGT MERGE) -->
<!-- ============================================================ -->

<SOURCE BUSINESSNAME="" DATABASETYPE="Oracle" DBDNAME="ORACLE_PROD" DESCRIPTION="Inventory staging" NAME="STG_INVENTORY" OBJECTVERSION="1" OWNERNAME="SALES">
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="1" NAME="PRODUCT_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="2" NAME="WAREHOUSE_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="3" NAME="QTY_ON_HAND" NULLABLE="NULL" PRECISION="10" SCALE="0"/>
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="4" NAME="QTY_RESERVED" NULLABLE="NULL" PRECISION="10" SCALE="0"/>
  <SOURCEFIELD DATATYPE="date" FIELDNUMBER="5" NAME="LAST_UPDATED" NULLABLE="NULL" PRECISION="19" SCALE="0"/>
  <SOURCEFIELD DATATYPE="varchar2" FIELDNUMBER="6" NAME="CHANGE_FLAG" NULLABLE="NULL" PRECISION="1" SCALE="0"/>
</SOURCE>

<TARGET BUSINESSNAME="" DATABASETYPE="Oracle" DESCRIPTION="Silver inventory dimension" NAME="DIM_INVENTORY" OBJECTVERSION="1">
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="1" KEYTYPE="PRIMARY KEY" NAME="PRODUCT_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="2" KEYTYPE="PRIMARY KEY" NAME="WAREHOUSE_ID" NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="3" KEYTYPE="NOT A KEY" NAME="QTY_ON_HAND" NULLABLE="NULL" PRECISION="10" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="4" KEYTYPE="NOT A KEY" NAME="QTY_RESERVED" NULLABLE="NULL" PRECISION="10" SCALE="0"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="5" KEYTYPE="NOT A KEY" NAME="QTY_AVAILABLE" NULLABLE="NULL" PRECISION="10" SCALE="0"/>
  <TARGETFIELD DATATYPE="date" FIELDNUMBER="6" KEYTYPE="NOT A KEY" NAME="LAST_UPDATED" NULLABLE="NULL" PRECISION="19" SCALE="0"/>
</TARGET>

<MAPPING DESCRIPTION="Upsert inventory records — insert new, update changed, delete flagged" ISVALID="YES" NAME="M_UPSERT_INVENTORY" OBJECTVERSION="1" VERSIONNUMBER="1">

  <!-- Source Qualifier -->
  <TRANSFORMATION DESCRIPTION="Read staging inventory" NAME="SQ_STG_INVENTORY" OBJECTVERSION="1" REUSABLE="NO" TYPE="Source Qualifier" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="PRODUCT_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="WAREHOUSE_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="QTY_ON_HAND" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="QTY_RESERVED" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="LAST_UPDATED" PORTTYPE="INPUT/OUTPUT" PRECISION="19" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="CHANGE_FLAG" PORTTYPE="INPUT/OUTPUT" PRECISION="1" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Sql Query" VALUE=""/>
  </TRANSFORMATION>

  <!-- Expression: Calculate available quantity -->
  <TRANSFORMATION DESCRIPTION="Derive available qty" NAME="EXP_CALC_AVAILABLE" OBJECTVERSION="1" REUSABLE="NO" TYPE="Expression" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="PRODUCT_ID" NAME="PRODUCT_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="WAREHOUSE_ID" NAME="WAREHOUSE_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="QTY_ON_HAND" NAME="QTY_ON_HAND" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="QTY_RESERVED" NAME="QTY_RESERVED" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" EXPRESSION="QTY_ON_HAND - NVL(QTY_RESERVED, 0)" NAME="QTY_AVAILABLE" PORTTYPE="OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="date/time" EXPRESSION="LAST_UPDATED" NAME="LAST_UPDATED" PORTTYPE="INPUT/OUTPUT" PRECISION="19" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" EXPRESSION="CHANGE_FLAG" NAME="CHANGE_FLAG" PORTTYPE="INPUT/OUTPUT" PRECISION="1" SCALE="0"/>
  </TRANSFORMATION>

  <!-- Update Strategy: Insert/Update/Delete based on CHANGE_FLAG -->
  <TRANSFORMATION DESCRIPTION="Route inserts, updates, deletes" NAME="UPD_INVENTORY" OBJECTVERSION="1" REUSABLE="NO" TYPE="Update Strategy" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="PRODUCT_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="WAREHOUSE_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="QTY_ON_HAND" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="QTY_RESERVED" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="QTY_AVAILABLE" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="LAST_UPDATED" PORTTYPE="INPUT/OUTPUT" PRECISION="19" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="string" NAME="CHANGE_FLAG" PORTTYPE="INPUT" PRECISION="1" SCALE="0"/>
    <TABLEATTRIBUTE NAME="Update Strategy Expression" VALUE="IIF(CHANGE_FLAG = 'I', DD_INSERT, IIF(CHANGE_FLAG = 'U', DD_UPDATE, IIF(CHANGE_FLAG = 'D', DD_DELETE, DD_REJECT)))"/>
  </TRANSFORMATION>

  <!-- Connectors: SQ → EXP → UPD → TGT -->
  <CONNECTOR FROMFIELD="PRODUCT_ID" FROMINSTANCE="SQ_STG_INVENTORY" FROMINSTANCETYPE="Source Qualifier" TOFIELD="PRODUCT_ID" TOINSTANCE="EXP_CALC_AVAILABLE" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="WAREHOUSE_ID" FROMINSTANCE="SQ_STG_INVENTORY" FROMINSTANCETYPE="Source Qualifier" TOFIELD="WAREHOUSE_ID" TOINSTANCE="EXP_CALC_AVAILABLE" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="QTY_ON_HAND" FROMINSTANCE="SQ_STG_INVENTORY" FROMINSTANCETYPE="Source Qualifier" TOFIELD="QTY_ON_HAND" TOINSTANCE="EXP_CALC_AVAILABLE" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="QTY_RESERVED" FROMINSTANCE="SQ_STG_INVENTORY" FROMINSTANCETYPE="Source Qualifier" TOFIELD="QTY_RESERVED" TOINSTANCE="EXP_CALC_AVAILABLE" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="LAST_UPDATED" FROMINSTANCE="SQ_STG_INVENTORY" FROMINSTANCETYPE="Source Qualifier" TOFIELD="LAST_UPDATED" TOINSTANCE="EXP_CALC_AVAILABLE" TOINSTANCETYPE="Expression"/>
  <CONNECTOR FROMFIELD="CHANGE_FLAG" FROMINSTANCE="SQ_STG_INVENTORY" FROMINSTANCETYPE="Source Qualifier" TOFIELD="CHANGE_FLAG" TOINSTANCE="EXP_CALC_AVAILABLE" TOINSTANCETYPE="Expression"/>

  <CONNECTOR FROMFIELD="PRODUCT_ID" FROMINSTANCE="EXP_CALC_AVAILABLE" FROMINSTANCETYPE="Expression" TOFIELD="PRODUCT_ID" TOINSTANCE="UPD_INVENTORY" TOINSTANCETYPE="Update Strategy"/>
  <CONNECTOR FROMFIELD="WAREHOUSE_ID" FROMINSTANCE="EXP_CALC_AVAILABLE" FROMINSTANCETYPE="Expression" TOFIELD="WAREHOUSE_ID" TOINSTANCE="UPD_INVENTORY" TOINSTANCETYPE="Update Strategy"/>
  <CONNECTOR FROMFIELD="QTY_ON_HAND" FROMINSTANCE="EXP_CALC_AVAILABLE" FROMINSTANCETYPE="Expression" TOFIELD="QTY_ON_HAND" TOINSTANCE="UPD_INVENTORY" TOINSTANCETYPE="Update Strategy"/>
  <CONNECTOR FROMFIELD="QTY_RESERVED" FROMINSTANCE="EXP_CALC_AVAILABLE" FROMINSTANCETYPE="Expression" TOFIELD="QTY_RESERVED" TOINSTANCE="UPD_INVENTORY" TOINSTANCETYPE="Update Strategy"/>
  <CONNECTOR FROMFIELD="QTY_AVAILABLE" FROMINSTANCE="EXP_CALC_AVAILABLE" FROMINSTANCETYPE="Expression" TOFIELD="QTY_AVAILABLE" TOINSTANCE="UPD_INVENTORY" TOINSTANCETYPE="Update Strategy"/>
  <CONNECTOR FROMFIELD="LAST_UPDATED" FROMINSTANCE="EXP_CALC_AVAILABLE" FROMINSTANCETYPE="Expression" TOFIELD="LAST_UPDATED" TOINSTANCE="UPD_INVENTORY" TOINSTANCETYPE="Update Strategy"/>
  <CONNECTOR FROMFIELD="CHANGE_FLAG" FROMINSTANCE="EXP_CALC_AVAILABLE" FROMINSTANCETYPE="Expression" TOFIELD="CHANGE_FLAG" TOINSTANCE="UPD_INVENTORY" TOINSTANCETYPE="Update Strategy"/>

  <CONNECTOR FROMFIELD="PRODUCT_ID" FROMINSTANCE="UPD_INVENTORY" FROMINSTANCETYPE="Update Strategy" TOFIELD="PRODUCT_ID" TOINSTANCE="DIM_INVENTORY" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="WAREHOUSE_ID" FROMINSTANCE="UPD_INVENTORY" FROMINSTANCETYPE="Update Strategy" TOFIELD="WAREHOUSE_ID" TOINSTANCE="DIM_INVENTORY" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="QTY_ON_HAND" FROMINSTANCE="UPD_INVENTORY" FROMINSTANCETYPE="Update Strategy" TOFIELD="QTY_ON_HAND" TOINSTANCE="DIM_INVENTORY" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="QTY_RESERVED" FROMINSTANCE="UPD_INVENTORY" FROMINSTANCETYPE="Update Strategy" TOFIELD="QTY_RESERVED" TOINSTANCE="DIM_INVENTORY" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="QTY_AVAILABLE" FROMINSTANCE="UPD_INVENTORY" FROMINSTANCETYPE="Update Strategy" TOFIELD="QTY_AVAILABLE" TOINSTANCE="DIM_INVENTORY" TOINSTANCETYPE="Target Definition"/>
  <CONNECTOR FROMFIELD="LAST_UPDATED" FROMINSTANCE="UPD_INVENTORY" FROMINSTANCETYPE="Update Strategy" TOFIELD="LAST_UPDATED" TOINSTANCE="DIM_INVENTORY" TOINSTANCETYPE="Target Definition"/>

  <TARGETLOADORDER ORDER="1" TARGETINSTANCE="DIM_INVENTORY"/>

</MAPPING>

</FOLDER>
</REPOSITORY>
</POWERMART>

      {
        "component": "cdq",
        "component_name": "Cloud Data Quality",
        "object_id": "cdq-prof-001",
        "name": "Customer_Table_Profile",
        "type": "dq_profile",
        "description": "Column profiling results for DIM_CUSTOMER table",
        "created_by": "dq_analyst",
